tr[flake8]
# Maximum line length — must match --max-line-length in tests.yml
max-line-length = 100

# Do not scan these folders for errors
exclude =
    __pycache__,
    .git,
    dist,
    build,
    *.egg-info,
    venv,
    .venv

# Ignore specific spacing rules to allow for manual alignment
extend-ignore =
    E203,
    W503,
    E221,
    E251,
    E272,
    E127