[flake8]
# Set the professional margin to 130 characters
max-line-length = 130

# Do not scan these folders for errors
exclude =
    __pycache__,
    .git,
    dist,
    build,
    *.egg-info

# Ignore specific spacing rules to allow for manual alignment
# (Like aligning dictionary keys or assignment operators)
extend-ignore =
    E203,
    W503,
    E221,
    E251,
    E272,
    E127